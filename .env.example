# =============================================================================
# Capture Hub - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# SQLite database URL for Prisma ORM
# For local development, use a relative path:
DATABASE_URL=file:./prisma/dev.db

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the server listens on (default: 3000)
PORT=3000

# Hostname binding (used in production; dev always uses localhost)
# HOSTNAME=0.0.0.0

# Node environment (development | production | test)
# NODE_ENV=development

# Server-side app URL for CSRF/origin validation in production
# APP_URL=https://capturehub.yourdomain.com

# Additional trusted origins for state-changing API requests (comma-separated)
# ALLOWED_ORIGINS=https://capturehub.yourdomain.com

# -----------------------------------------------------------------------------
# WebSocket Configuration
# -----------------------------------------------------------------------------
# Public WebSocket URL for client connections
# If not set, the client auto-detects based on window.location
# Examples:
#   ws://localhost:3000/ws        (local development)
#   wss://yourdomain.com/ws       (production with TLS)
# NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws

# -----------------------------------------------------------------------------
# PostgreSQL Configuration (Project Omni P2 - Platform)
# -----------------------------------------------------------------------------
# To switch from SQLite to PostgreSQL, change DATABASE_URL to:
# DATABASE_URL=postgresql://capture_hub:capture_hub_dev@localhost:5432/capture_hub?schema=public
#
# PostgreSQL connection settings (used by docker-compose.platform.yml)
# POSTGRES_USER=capture_hub
# POSTGRES_PASSWORD=capture_hub_dev
# POSTGRES_DB=capture_hub
# POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Redis Configuration (Event Mesh backing store)
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
# REDIS_PORT=6379

# -----------------------------------------------------------------------------
# AI / API Keys
# -----------------------------------------------------------------------------
# z-ai-web-dev-sdk API key for AI-powered features:
#   - OCR text extraction (VLM-based)
#   - Auto-tagging suggestions
#   - Search ranking enhancement
#   - Content summarization
#   - Dashboard insights
# At least one of these must be set for AI features to work.
# If neither is set, AI features gracefully degrade (return empty/fallback results).
# ZAI_API_KEY=your-zai-api-key-here
# OPENAI_API_KEY=your-openai-api-key-here

# -----------------------------------------------------------------------------
# Project Omni Configuration
# -----------------------------------------------------------------------------
# Omni modules are enabled automatically. No additional env vars required.
# Module status is visible at GET /api/health under the "omni" key.
#
# Modules:
#   P1 contracts  — Zod-validated event schemas, API contracts, edge gateway
#   P2 platform   — PostgreSQL + pgvector IaC, event mesh bridge, dual DB support
#   P4 ai         — Provider abstraction (ZAI/mock), embedding pipeline, RAG engine
#   P5 ux-hooks   — Typed API client, real-time event hooks, AI-aware UI hooks
#
# AI Provider Selection (automatic):
#   - ZAI_API_KEY set   → uses ZAI provider (full AI features)
#   - Nothing set       → uses mock provider (graceful degradation, deterministic)
#
# Embedding Pipeline:
#   - PostgreSQL → stores vectors in pgvector Embedding table
#   - SQLite     → stores vectors in-memory (dev/testing only)
